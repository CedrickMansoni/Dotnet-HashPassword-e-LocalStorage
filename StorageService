public interface IDeleteFile
{
    Task<string> DeleteAsync(string caminhoArquivo);
}
----------------------------------------------------------------------------------
public class DeleteFile : IDeleteFile
{
    public async Task<string> DeleteAsync(string caminhoArquivo)
    {
        if (string.IsNullOrWhiteSpace(caminhoArquivo)) return "Caminho do arquivo não pode ser vazio";
        
        try
        {
            // Verificar se o arquivo existe
            if (!File.Exists(caminhoArquivo)) return "Arquivo não encontrado";
            
            // Deletar o arquivo de forma assíncrona
            await Task.Run(() => File.Delete(caminhoArquivo));
            return "Arquivo deletado com sucesso";
        }
        catch (Exception ex)
        {
            // Log da exceção pode ser adicionado aqui
            return $"Erro ao deletar arquivo: {ex.Message}";
        }
    }
}
